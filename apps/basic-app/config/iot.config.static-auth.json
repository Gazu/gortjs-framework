{
  "runtime": {
    "driver": "mock"
  },
  "devices": [
    {
      "id": "temp1",
      "type": "temperature",
      "pin": "A0",
      "options": {
        "freq": 1500,
        "unit": "raw"
      }
    },
    {
      "id": "led1",
      "type": "led",
      "pin": 13
    },
    {
      "id": "relay1",
      "type": "relay",
      "pin": 7
    }
  ],
  "rules": [
    {
      "id": "high_temp_alert",
      "eventName": "device:temp1:sensor:reading",
      "cooldownMs": 250,
      "condition": {
        "path": "payload.value",
        "operator": "gt",
        "value": 60
      },
      "actions": [
        {
          "deviceId": "relay1",
          "command": "open"
        },
        {
          "deviceId": "led1",
          "command": "on"
        }
      ]
    }
  ],
  "workflows": [
    {
      "id": "heartbeat_led",
      "trigger": {
        "schedule": {
          "everyMs": 3000,
          "runAtStartup": true
        }
      },
      "steps": [
        {
          "type": "command",
          "deviceId": "led1",
          "command": "toggle"
        }
      ]
    }
  ],
  "rest": {
    "port": 3000,
    "websocketPath": "/ws",
    "auth": {
      "mode": "static",
      "token": "gortjs-static-demo-token",
      "tokenScopes": [
        "gortjs:read",
        "gortjs:write",
        "gortjs:stream",
        "gortjs:metrics",
        "gortjs:admin"
      ],
      "scopes": {
        "status:read": ["gortjs:read"],
        "snapshot:read": ["gortjs:read"],
        "health:read": ["gortjs:read"],
        "health:deep:read": ["gortjs:read"],
        "metrics:read": ["gortjs:metrics"],
        "devices:read": ["gortjs:read"],
        "device-types:read": ["gortjs:read"],
        "rules:read": ["gortjs:read"],
        "workflows:read": ["gortjs:read"],
        "events:read": ["gortjs:read"],
        "persisted-state:read": ["gortjs:read"],
        "devices:write": ["gortjs:write"],
        "commands:write": ["gortjs:write"],
        "rules:write": ["gortjs:write"],
        "lifecycle:write": ["gortjs:admin"],
        "ws:connect": ["gortjs:stream"]
      }
    }
  },
  "persistence": {
    "directory": "../data",
    "eventLogFile": "events.jsonl",
    "stateFile": "state.json",
    "maxEvents": 500,
    "rotateAfterBytes": 32768,
    "maxBackups": 5
  }
}
