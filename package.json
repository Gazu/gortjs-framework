{
  "name": "gortjs-framework",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "find . -name dist -type d -prune -exec rm -rf {} + && find . -name '*.tsbuildinfo' -delete",
    "start": "tsx apps/basic-app/src/main.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.1",
    "@types/express": "^5.0.0"
  }
}
